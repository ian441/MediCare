// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USERS & AUTHENTICATION ============

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  phoneNumber String?
  firstName String
  lastName  String
  passwordHash String
  role      UserRole @default(PATIENT)
  status    UserStatus @default(ACTIVE)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Relations
  patient     Patient?
  doctor      Doctor?
  supportTickets SupportTicket[]
  auditLogs   AuditLog[]

  @@index([email])
  @@index([role])
  @@index([status])
}

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ============ PATIENT DATA ============

model Patient {
  id            String   @id @default(cuid())
  userId        String   @unique
  dateOfBirth   DateTime
  gender        Gender?
  bloodType     String?
  emergencyContactName String?
  emergencyContactPhone String?
  allergies     String?
  chronicConditions String?
  insuranceProvider String?
  insuranceNumber String?
  medicalHistory Json?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  prescriptions   Prescription[]
  medicalRecords  MedicalRecord[]
  pharmacyOrders  PharmacyOrder[]
  testimonials    Testimonial[]
  reviews         Testimonial[]
  cart            PharmacyCart[]

  @@index([insuranceProvider])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// ============ DOCTOR DATA ============

model Doctor {
  id              String   @id @default(cuid())
  userId          String   @unique
  specialtyId     String
  departmentId    String?
  licenseNumber   String   @unique
  licenseExpiry   DateTime?
  bio             String?
  experienceYears Int?
  education       Json?
  availabilityDays String[]
  languages       String[]
  consultationFee Decimal  @db.Decimal(10, 2)
  rating          Decimal  @default(0) @db.Decimal(3, 2)
  totalReviews    Int      @default(0)
  isAvailable     Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty         Specialty @relation(fields: [specialtyId], references: [id])
  department        Department? @relation(fields: [departmentId], references: [id])
  appointments      Appointment[]
  medicalRecords    MedicalRecord[]
  prescriptions     Prescription[]
  availability      DoctorAvailability[]
  telemedicineSessions TelemedicineSession[]
  testimonials      Testimonial[]
  departmentHead    Department[] @relation("DepartmentHead")

  @@index([specialtyId])
  @@index([departmentId])
  @@index([isAvailable])
}

model Specialty {
  id          String @id @default(cuid())
  name        String @unique
  description String?
  iconName    String?
  
  createdAt DateTime @default(now())

  // Relations
  doctors     Doctor[]
  services    Service[]

  @@index([name])
}

model Department {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String?
  headDoctorId  String?
  phone         String?
  email         String?
  
  createdAt DateTime @default(now())

  // Relations
  doctors       Doctor[]
  headDoctor    Doctor? @relation("DepartmentHead", fields: [headDoctorId], references: [id])

  @@index([name])
}

model DoctorAvailability {
  id              String @id @default(cuid())
  doctorId        String
  dayOfWeek       Int    // 0=Sunday, 6=Saturday
  startTime       DateTime @db.Time()
  endTime         DateTime @db.Time()
  lunchBreakStart DateTime? @db.Time()
  lunchBreakEnd   DateTime? @db.Time()
  isAvailable     Boolean @default(true)
  
  createdAt DateTime @default(now())

  // Relations
  doctor          Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek])
  @@index([doctorId])
}

// ============ SERVICES & APPOINTMENTS ============

model Service {
  id                String @id @default(cuid())
  name              String
  description       String?
  longDescription   String?
  specialtyId       String
  category          String?
  priceMin          Decimal @db.Decimal(10, 2)
  priceMax          Decimal? @db.Decimal(10, 2)
  durationMinutes   Int?
  isAvailable       Boolean @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  specialty         Specialty @relation(fields: [specialtyId], references: [id])
  appointments      Appointment[]

  @@index([specialtyId])
  @@index([category])
  @@index([isAvailable])
}

model Appointment {
  id                String @id @default(cuid())
  patientId         String
  doctorId          String
  serviceId         String
  appointmentDate   DateTime @db.Date()
  appointmentTime   DateTime @db.Time()
  durationMinutes   Int @default(30)
  status            AppointmentStatus @default(SCHEDULED)
  notes             String?
  consultationFee   Decimal? @db.Decimal(10, 2)
  paymentStatus     PaymentStatus @default(PENDING)
  appointmentType   AppointmentType @default(IN_CLINIC)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  cancelledAt       DateTime?
  completedAt       DateTime?

  // Relations
  patient           Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor            Doctor @relation(fields: [doctorId], references: [id])
  service           Service @relation(fields: [serviceId], references: [id])
  prescription      Prescription?
  telemedicineSession TelemedicineSession?

  @@unique([doctorId, appointmentDate, appointmentTime])
  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentDate])
  @@index([status])
  @@index([appointmentType])
  @@index([doctorId, appointmentDate])
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentType {
  IN_CLINIC
  TELEMEDICINE
  HOME_VISIT
}

// ============ MEDICAL RECORDS ============

model MedicalRecord {
  id              String @id @default(cuid())
  patientId       String
  recordType      RecordType
  description     String?
  data            Json?
  recordedByDoctorId String?
  recordDate      DateTime @default(now())
  
  createdAt       DateTime @default(now())

  // Relations
  patient         Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recordedByDoctor Doctor? @relation(fields: [recordedByDoctorId], references: [id])

  @@index([patientId])
  @@index([recordType])
  @@index([recordDate])
}

enum RecordType {
  DIAGNOSIS
  PRESCRIPTION
  LAB_RESULT
  IMAGING
  PROCEDURE_NOTE
  VITAL_SIGNS
}

model Prescription {
  id              String @id @default(cuid())
  appointmentId   String @unique
  patientId       String
  doctorId        String
  medicineId      String
  dosage          String
  frequency       String
  durationDays    Int
  instructions    String?
  status          PrescriptionStatus @default(ACTIVE)
  prescribedDate  DateTime @default(now())
  
  createdAt       DateTime @default(now())

  // Relations
  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient         Patient @relation(fields: [patientId], references: [id])
  doctor          Doctor @relation(fields: [doctorId], references: [id])
  medicine        Medicine @relation(fields: [medicineId], references: [id])
  cartItems       PharmacyCart[]

  @@index([patientId])
  @@index([status])
}

enum PrescriptionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// ============ PHARMACY ============

model Medicine {
  id                  String @id @default(cuid())
  name                String
  genericName         String?
  category            String
  manufacturer        String?
  strength            String?
  form                MedicineForm?
  unitPrice           Decimal @db.Decimal(10, 2)
  currentStock        Int @default(0)
  reorderLevel        Int @default(50)
  requiresPrescription Boolean @default(false)
  expiryDate          DateTime?
  description         String?
  sideEffects         Json?
  contraindications   Json?
  isAvailable         Boolean @default(true)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  prescriptions       Prescription[]
  cartItems           PharmacyCart[]
  orderItems          PharmacyOrderItem[]

  @@index([name])
  @@index([category])
  @@index([currentStock])
}

enum MedicineForm {
  TABLET
  CAPSULE
  LIQUID
  INJECTION
  INHALER
  CREAM
  PATCH
}

model PharmacyCart {
  id                  String @id @default(cuid())
  patientId           String
  medicineId          String
  quantity            Int @default(1)
  unitPrice           Decimal @db.Decimal(10, 2)
  requiresPrescription Boolean?
  prescriptionId      String?
  addedAt             DateTime @default(now())

  // Relations
  patient             Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medicine            Medicine @relation(fields: [medicineId], references: [id])
  prescription        Prescription? @relation(fields: [prescriptionId], references: [id])

  @@unique([patientId, medicineId])
  @@index([patientId])
}

model PharmacyOrder {
  id                String @id @default(cuid())
  orderNumber       String @unique
  patientId         String
  totalAmount       Decimal @db.Decimal(12, 2)
  paymentStatus     PaymentStatus @default(PENDING)
  orderStatus       OrderStatus @default(PENDING)
  deliveryType      DeliveryType @default(PICKUP)
  deliveryAddress   String?
  deliveryDate      DateTime?
  trackingNumber    String?
  notes             String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deliveredAt       DateTime?

  // Relations
  patient           Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  items             PharmacyOrderItem[]

  @@index([patientId])
  @@index([orderStatus])
  @@index([createdAt])
}

model PharmacyOrderItem {
  id              String @id @default(cuid())
  orderId         String
  medicineId      String
  quantity        Int
  unitPrice       Decimal @db.Decimal(10, 2)
  subtotal        Decimal @db.Decimal(12, 2)

  // Relations
  order           PharmacyOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  medicine        Medicine @relation(fields: [medicineId], references: [id])

  @@index([orderId])
}

enum OrderStatus {
  PENDING
  PROCESSING
  READY_FOR_PICKUP
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DeliveryType {
  PICKUP
  HOME_DELIVERY
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

// ============ TELEMEDICINE ============

model TelemedicineSession {
  id                String @id @default(cuid())
  appointmentId     String @unique
  patientId         String
  doctorId          String
  sessionToken      String?
  videoProvider     VideoProvider @default(TWILIO)
  sessionStartTime  DateTime?
  sessionEndTime    DateTime?
  durationMinutes   Int?
  status            TelemedicineStatus @default(SCHEDULED)
  recordingUrl      String?
  notes             String?
  
  createdAt         DateTime @default(now())

  // Relations
  appointment       Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient           Patient @relation(fields: [patientId], references: [id])
  doctor            Doctor @relation(fields: [doctorId], references: [id])
  messages          TelemedicineMessage[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
}

enum VideoProvider {
  TWILIO
  JITSI
  AGORA
}

enum TelemedicineStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model TelemedicineMessage {
  id              String @id @default(cuid())
  sessionId       String
  senderId        String
  senderType      MessageSenderType
  messageText     String?
  messageType     MessageType @default(TEXT)
  fileUrl         String?
  
  createdAt       DateTime @default(now())

  // Relations
  session         TelemedicineSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

enum MessageSenderType {
  PATIENT
  DOCTOR
}

enum MessageType {
  TEXT
  FILE
  PRESCRIPTION
}

// ============ BLOG & CONTENT ============

model BlogPost {
  id              String @id @default(cuid())
  title           String
  slug            String @unique
  excerpt         String?
  content         String
  authorId        String
  category        String?
  tags            String[]
  featuredImageUrl String?
  viewsCount      Int @default(0)
  isPublished     Boolean @default(false)
  publishedAt     DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  author          Doctor @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([isPublished])
  @@index([category])
}

// ============ REVIEWS & TESTIMONIALS ============

model Testimonial {
  id              String @id @default(cuid())
  patientId       String
  doctorId        String
  serviceId       String?
  rating          Int // 1-5
  comment         String?
  isVerified      Boolean @default(false)
  isPublished     Boolean @default(false)
  
  createdAt       DateTime @default(now())

  // Relations
  patient         Patient @relation("PatientTestimonials", fields: [patientId], references: [id], onDelete: Cascade)
  doctor          Doctor @relation(fields: [doctorId], references: [id])
  service         Service? @relation(fields: [serviceId], references: [id])

  @@index([doctorId])
  @@index([isVerified])
}

// ============ PAYMENTS ============

model Payment {
  id                String @id @default(cuid())
  transactionId     String @unique
  userId            String
  appointmentId     String?
  pharmacyOrderId   String?
  amount            Decimal @db.Decimal(12, 2)
  currency          String @default("KES")
  paymentMethod     PaymentMethod
  paymentGateway    String?
  gatewayReference  String?
  status            PaymentStatus @default(PENDING)
  metadata          Json?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations (no FK to avoid circular deps, just IDs)
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum PaymentMethod {
  CREDIT_CARD
  MPESA
  BANK_TRANSFER
  WALLET
}

// ============ CUSTOMER SUPPORT ============

model SupportTicket {
  id                String @id @default(cuid())
  ticketNumber      String @unique
  userId            String
  subject           String
  description       String?
  priority          TicketPriority @default(MEDIUM)
  status            TicketStatus @default(OPEN)
  assignedToUserId  String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  resolvedAt        DateTime?

  // Relations
  user              User @relation(fields: [userId], references: [id])
  messages          SupportMessage[]

  @@index([userId])
  @@index([status])
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

model SupportMessage {
  id              String @id @default(cuid())
  ticketId        String
  senderId        String
  message         String
  attachmentUrl   String?
  isInternal      Boolean @default(false)
  
  createdAt       DateTime @default(now())

  // Relations
  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender          User @relation(fields: [senderId], references: [id])

  @@index([ticketId])
}

// ============ SYSTEM ============

model Notification {
  id              String @id @default(cuid())
  recipientId     String
  notificationType NotificationType
  eventType       EventType
  subject         String?
  content         String
  status          NotificationStatus @default(PENDING)
  relatedEntityId String?
  
  createdAt       DateTime @default(now())
  sentAt          DateTime?
}

enum NotificationType {
  EMAIL
  SMS
  PUSH
}

enum EventType {
  APPOINTMENT_REMINDER
  APPOINTMENT_CONFIRMED
  ORDER_STATUS
  PRESCRIPTION_READY
  PAYMENT_RECEIPT
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
}

model AuditLog {
  id              String @id @default(cuid())
  userId          String?
  action          String
  entityType      String
  entityId        String?
  oldValues       Json?
  newValues       Json?
  ipAddress       String?
  userAgent       String?
  
  createdAt       DateTime @default(now())

  // Relations
  user            User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model SystemSetting {
  id              String @id @default(cuid())
  settingKey      String @unique
  settingValue    String
  dataType        String
  description     String?
  updatedBy       String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
