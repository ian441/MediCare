# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Database Configuration
DATABASE_URL=postgresql://postgres:Retry4x@localhost:5432/medicare_db

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_min_32_chars
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# External Services - Email/SMS
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@medicare.ke

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+254XXXXXXXXX

# Payment Gateways
PESAPAL_API_KEY=your_pesapal_api_key
PESAPAL_API_SECRET=your_pesapal_secret

MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=your_mpesa_shortcode
MPESA_PASSKEY=your_mpesa_passkey

# File Storage (AWS S3 or equivalent)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=medicare-files

# Telemedicine (Twilio Video)
TWILIO_API_KEY=your_twilio_video_api_key
TWILIO_VIDEO_ROOM_PREFIX=medicare-consultation

# Admin Configuration
ADMIN_EMAIL=admin@medicare.ke
ADMIN_PASSWORD_TEMP=ChangeMe123!

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=your_session_secret_key_min_32_chars
SESSION_EXPIRY=24h

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# Database Encryption Key
ENCRYPTION_KEY=your_32_char_encryption_key_hex_string

# Application Keys
APP_NAME=MediCare Clinic
APP_VERSION=1.0.0
